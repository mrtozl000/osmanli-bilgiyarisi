# Copy to .env.local for local dev; set these in the Vercel dashboard for prod.

# Neon Postgres — "Pooled connection" string from Neon dashboard
DATABASE_URL="postgresql://user:pass@host-pooler.neon.tech/dbname?sslmode=require"

# Your iOS app's bundle identifier. Must match exactly what Apple sees as `aud` in the JWT.
APPLE_BUNDLE_ID="com.osmanli.bilgiyarisi"

# Long random secret for signing your own session JWTs. Generate with: openssl rand -hex 64
SESSION_SECRET="replace-with-openssl-rand-hex-64-output"

# From RevenueCat dashboard → Project settings → Integrations → Webhooks → Authorization header
REVENUECAT_WEBHOOK_SECRET="replace-with-revenuecat-webhook-auth-header-value"
